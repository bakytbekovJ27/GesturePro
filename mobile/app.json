{
  "expo": {
    "name": "GesturePro Mobile",
    "slug": "gesturepro",
    "scheme": "gesturepro",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "newArchEnabled": true,
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.gesturepro-mobile"
    },
    "android": {
      "package": "com.gesturepro.gesturepro"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "db9af8ce-11ad-4128-be56-739dfe8cda2c"
      }
    },
    "owner": "gesturepro"
  }
}
