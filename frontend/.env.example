# Optional override. By default the frontend uses the current page host and port 8000.
# Local example:
# VITE_API_URL=http://localhost:8000

# Phone / LAN override example:
# Replace <LAN-IP> with your laptop IP, for example 192.168.51.99
# VITE_API_URL=http://<LAN-IP>:8000

# Legacy full-prefix override:
# VITE_API_BASE_URL=http://localhost:8000/api/v1
