DJANGO_SECRET_KEY=change-me-for-production
DJANGO_DEBUG=true

# Local laptop-only development:
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
DJANGO_CORS_ALLOW_ALL_ORIGINS=true
DJANGO_CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Phone / LAN development example:
# Replace <LAN-IP> with your laptop IP, for example 192.168.0.105
# DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,<LAN-IP>
# DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://<LAN-IP>:8000
# DJANGO_CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://<LAN-IP>:5173

DJANGO_TIME_ZONE=Asia/Almaty
SESSION_LIFETIME_HOURS=24
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
